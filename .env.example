# ==========================================
# MedoraAI — Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values.
# Set SECRET_KEY for real deployments. LLM API keys are optional; without them,
# the backend uses the built-in report template fallback.

# --- Security ---
SECRET_KEY=medoraai-change-this-in-production

# --- LLM API Keys (Gemini is preferred for image-aware reports) ---
# Gemini can inspect the uploaded image and combine that with ML output.
# Sign up at https://aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# Fail closed before diagnostic inference when the upload is the wrong anatomy,
# wrong modality, a poster/collage, or uncertain.
STRICT_SCAN_TYPE_VALIDATION=true
# Leave blank to reuse GEMINI_MODEL.
SCAN_TYPE_VERIFIER_MODEL=
SCAN_TYPE_GROQ_MODEL=qwen/qwen3.6-27b
SCAN_TYPE_MIN_CONFIDENCE=0.85

# Patient-language translation. The backend sends only the simplified English
# explanation to this endpoint, never the scan image.
SARVAM_API_KEY=
SARVAM_TRANSLATE_MODEL=sarvam-translate:v1

# --- Text-only fallback providers ---
# Groq is recommended: free tier, fastest inference (Llama 3.1 70B)
# Sign up at https://console.groq.com
GROQ_API_KEY=

# Anthropic Claude (secondary fallback)
# Sign up at https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI GPT (tertiary fallback)
# Sign up at https://platform.openai.com
OPENAI_API_KEY=

# --- Demo Credentials ---
DEMO_USER=demo
DEMO_PASSWORD=demo123

# --- ML Models ---
# These are the expected local artifact names for the current backend.
CHEST_MODEL_PATH=./models/chest_xray_efficientnet_b4.pt
BRAIN_MODEL_PATH=./models/best_brain_model.keras

# --- Server ---
# DEBUG=false
# LOG_LEVEL=info
